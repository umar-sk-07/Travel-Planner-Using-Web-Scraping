# Never copy local env files into images
.env
.env.local
.env.production
.env.development

# Git
.git
.gitignore

# Node modules (each image installs its own)
node_modules
frontend/node_modules
backend/node_modules

# Next.js build output (built inside container)
.next
frontend/.next

# Backend build output (built inside container)
backend/dist

# Misc
*.log
dump.rdb
db_backup
